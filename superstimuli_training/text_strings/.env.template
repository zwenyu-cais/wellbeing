# === Model Paths ===
# Set these to local paths if models are pre-downloaded, or use HuggingFace hub IDs.
# HF hub IDs (e.g., "meta-llama/Llama-3.1-8B-Instruct") will auto-download on first use.

# Policy models (small, trainable)
LLAMA_8B_PATH=meta-llama/Llama-3.1-8B-Instruct
QWEN25_7B_PATH=Qwen/Qwen2.5-7B-Instruct

# Target/judge models (large, for reward computation)
LLAMA_70B_PATH=meta-llama/Llama-3.3-70B-Instruct
QWEN_72B_PATH=Qwen/Qwen2.5-72B-Instruct
GEMMA_27B_PATH=google/gemma-2-27b-it

# === Data Paths ===
DATA_DIR=$HOME/data/superstimuli

# === Output Paths ===
OUTPUT_DIR=./results/rollout_data

# === SLURM Settings ===
SLURM_PARTITION=gpu
# SLURM_ACCOUNT=           # Optional: set if your cluster requires --account
# SLURM_QOS=               # Optional: set QoS if required

# === Conda Environment ===
CONDA_ENV=euphorics_text

# === HuggingFace Settings ===
# HF_HOME=                # Optional: override HF cache location
# HF_HUB_CACHE=           # Optional: override HF hub cache (used by vLLM)
# HF_HUB_OFFLINE=1        # Uncomment if models are pre-cached locally

