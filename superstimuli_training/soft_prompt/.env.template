# Copy this file to .env and fill in your values.

# Paths
HYDRA_OUTPUT_ROOT=/path/to/hydra/output
SWEEP_OUTPUT_ROOT=/path/to/sweep/outputs
CONDA_BASE=/path/to/conda
CONDA_ENV=euphorics_soft_prompt

# API keys
LITELLM_API_KEY=your-litellm-api-key
WANDB_API_KEY=your-wandb-api-key
# WANDB_ENTITY=            # Optional: set to avoid 400 on wandb sweep resume

# SLURM settings
SLURM_PARTITION=gpu
SLURM_CPU_PARTITION=cpu
# SLURM_ACCOUNT=           # Optional: set if your cluster requires --account
# SLURM_QOS=               # Optional: set QoS if required
