# Copy this file to .env and fill in your values.

# Conda
CONDA_BASE=/path/to/conda
CONDA_ENV=evaluation_soft_prompt

# Hugging Face cache
HF_HOME=/path/to/huggingface
# HF_HUB_CACHE=            # Optional: override HF hub cache (used by vLLM)

# Wellbeing evals cache (vocab expansion + embedding cache)
WELLBEING_EVALS_CACHE_DIR=/path/to/cache/wellbeing_evals

# Soft prompt outputs
SOFT_PROMPT_BASE_DIR=/path/to/soft_prompt/outputs

# Eval outputs (dirname under superstimuli_evaluation/soft_prompt/)
# EVAL_OUTPUTS_DIR=outputs

# API keys / endpoints
# LITELLM_API_KEY=         # Required for mtbench judge + self_report grok client
# OPENAI_BASE_URL=         # Optional: LiteLLM proxy URL (default: https://litellm.app)

# vLLM generation concurrency (wellbeing_index generate_sp)
# VLLM_CONCURRENCY=32

# SLURM settings
SLURM_PARTITION=gpu
SLURM_CPU_PARTITION=cpu
# SLURM_ACCOUNT=           # Optional: set if your cluster requires --account
# SLURM_QOS=               # Optional: set QoS if required
