# === Conda Environment ===
CONDA_ENV=image_superstimuli

# === Wellbeing-Dev Root ===
# Absolute path to this checkout of wellbeing-dev. Used by the eval runner
# (superstimuli_evaluation/images/runner.py) to locate experiments, configs,
# and shared utilities.
WELLBEING_DEV_ROOT=/path/to/wellbeing-dev

# === Python Environment ===
# Path to Python venv (if not using conda). Leave blank to use CONDA_ENV.
VENV_PATH=

# === Model Paths ===
# Set these to local paths if models are pre-downloaded, or use HuggingFace hub IDs.
# HF hub IDs (e.g., "Qwen/Qwen2.5-VL-32B-Instruct") will auto-download on first use.
QWEN25_VL_32B_PATH=Qwen/Qwen2.5-VL-32B-Instruct
QWEN25_VL_72B_PATH=Qwen/Qwen2.5-VL-72B-Instruct
QWEN3_VL_32B_PATH=Qwen/Qwen3-VL-32B-Instruct

# === Data Paths ===
# Cluster data root containing per-experiment image assets (superstimuli pools,
# beautiful image reference set, eval configs, etc). Default cluster path is
# /data/superstimuli_group; external users can mirror that layout anywhere.
SUPERSTIMULI_DIR=/data/superstimuli_group

# Natural image reference pool used to build preference comparisons.
PREFERENCE_DATA_DIR=./data/preference_data

# === Output Paths ===
TRAIN_OUTPUT_DIR=./outputs
EVAL_OUTPUT_DIR=./eval/results

# Base directory for evaluation images. Point to the repo's assets/ directory
# to use the pre-computed images shipped with the repo:
#   EVAL_IMAGES_DIR=./assets
EVAL_IMAGES_DIR=./assets

# === SLURM Settings (optional) ===
# SLURM_PARTITION=gpu
# SLURM_ACCOUNT=

# === HuggingFace Settings ===
# HF_HOME=
# HF_HUB_OFFLINE=1
