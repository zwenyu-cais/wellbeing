# === Model Paths ===
# Target/judge models (used by Stage 2 Thurstonian ranking + paraphrase prompting).
# Set to local paths if pre-downloaded, or use HuggingFace hub IDs.
LLAMA_70B_PATH=meta-llama/Llama-3.3-70B-Instruct
QWEN_72B_PATH=Qwen/Qwen2.5-72B-Instruct
GEMMA_27B_PATH=google/gemma-2-27b-it

# === Data Paths ===
# Training rollouts that analysis reads from (relative to this eval dir).
OUTPUT_DIR=../../superstimuli_training/text_strings/results/rollout_data

# === Output Paths ===
ANALYSIS_OUTPUT_DIR=./results/best_strings
EVALUATE_OUTPUT_DIR=./results/evaluate

# === SLURM Settings ===
SLURM_PARTITION=gpu
# SLURM_ACCOUNT=           # Optional: set if your cluster requires --account
# SLURM_QOS=               # Optional: set QoS if required

# === Conda Environment ===
CONDA_ENV=euphorics_text

# === HuggingFace Settings ===
# HF_HOME=                # Optional: override HF cache location
# HF_HUB_CACHE=           # Optional: override HF hub cache (used by vLLM)
# HF_HUB_OFFLINE=1        # Uncomment if models are pre-cached locally

# === LiteLLM Proxy (used by evaluate/generate_variations_cache.py) ===
# LITELLM_API_KEY=        # Required for variation generation via LiteLLM
# OPENAI_BASE_URL=        # LiteLLM proxy base URL (e.g. https://litellm.app)
